# =============================================================================
# 🦐 DSV4 Flash Dual DGX Spark Deployment — .env Template
# 中英双语配置模板
# =============================================================================
# Copy this file to .env and edit for your environment.
# 复制为.env并修改你的环境配置。

# ===== Docker Image · 镜像 =====
# Image from bjk110/spark_vllm_docker (jasl/vLLM fork)
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:dsv4-d568

# ===== Model Paths · 模型路径 =====
# Path to DeepSeek V4 Flash weights on your machine
# 你的机器上DeepSeek V4 Flash权重路径
MODEL_PATH=/path/to/DeepSeek-V4-Flash/20260528
# Path inside container (don't change unless you modify entrypoint)
# 容器内路径（除非改entrypoint否则不要动）
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
# API model name
SERVED_MODEL_NAME=deepseek-v4-flash

# ===== Cluster · 集群 =====
CLUSTER_MODE=dual-rdma
# Tensor parallel size: 2 = 2 nodes × 1 GPU each
# 张量并行大小：2=双机各1卡
TP_SIZE=2
# Distributed backend: mp (recommended for nnodes>1) or ray
# 分布式后端：mp（推荐）或 ray
DISTRIBUTED_BACKEND=mp
# RoCE IPs for P2P communication between DGX Sparks
# 双机RoCE网络IP
HEAD_ROCE_IP=10.65.100.1     # Your Node A's RoCE IP  你的A机RoCE地址
WORKER_ROCE_IP=10.65.100.2    # Your Node B's RoCE IP  你的B机RoCE地址
ROCE_IF_NAME=enp1s0f0np0      # RoCE network interface  RoCE网卡名
IB_HCA_NAME=rocep1s0f0,roceP2p1s0f0  # IB HCA devices  IB设备名

# ===== Serving · 服务 =====
HOST_PORT=8000
# First-run conservative: 8192. Gradual upgrade: 32768 → 131072 → 524288
# 首跑保守8192，逐步升级
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.78
# DSV4-specific model arguments
# DSV4专属模型参数
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --enable-expert-parallel --block-size 256 --tokenizer-mode deepseek_v4 --load-format safetensors

# ===== ⭐ CRITICAL GB10 Parameters · 关键GB10参数 =====
# Without these, deployment WILL fail on DGX Spark GB10
# 不加这些在DGX Spark GB10上一定失败

# GB10 has no NVLink — disable P2P
# GB10没有NVLink——禁用P2P
NCCL_P2P_DISABLE=1
# GB10 has no NVLS — NVLS code path hangs MoE
# GB10没有NVLS——NVLS路径导致MoE路由挂死
NCCL_NVLS_ENABLE=0
# Container lacks IB verbs plugin — fallback to Socket TCP
# 容器缺IB verbs插件——回退到Socket TCP
NCCL_NET=Socket
NCCL_IB_DISABLE=1
# Disable FlashInfer sampler — sm75 check fails on SM12x
# 禁用FlashInfer采样器——SM12x通不过sm75检查
VLLM_USE_FLASHINFER_SAMPLER=0
# Skip CUDA graph memory estimation — avoids empty string crash
# 跳过CUDA图内存预估——避免空字符串崩溃
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0
# Suppress FlashInfer version check
FLASHINFER_DISABLE_VERSION_CHECK=1

# ===== Performance · 性能 =====
VLLM_TRITON_MLA_SPARSE=1
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
