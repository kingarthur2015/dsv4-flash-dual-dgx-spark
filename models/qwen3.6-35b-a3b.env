# =============================================================================
# Qwen/Qwen3.6-35B-A3B — TP=1 Single-Node
#
# Architecture (Qwen3_5MoeForConditionalGeneration, hybrid MoE multimodal):
#   - model_type=qwen3_5_moe (wrapper config with nested text_config + vision_config)
#   - 40 layers (hybrid Mamba/Attention)
#   - hidden_size 2048, GQA 16→2, head_dim ?
#   - 256 experts, top-8 active (~3B active params)
#   - moe_intermediate_size 512
#   - vocab 248320, max_position 262144 (served at 32768)
#
# Sizing on single GB10 (121 GiB unified):
#   - BF16 weights ~67 GB on disk → fits one node with KV-cache headroom
#
# Image: v022-d568 (NGC 26.04 base + vLLM v0.21.0 + PR#35568 cherry-pick
#                   + FlashInfer 0.6.11.post3 + Transformers 5.8.1
#                   + Triton 3.7.0 + NCCL 2.30.4).
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v022-d568

# ---- Model ----
MODEL_PATH=[model_path]/Qwen/Qwen_Qwen3.6-35B-A3B
MODEL_CONTAINER_PATH=/models/Qwen3.6-35B-A3B
SERVED_MODEL_NAME=Qwen/Qwen3.6-35B-A3B

# ---- Cluster ----
CLUSTER_MODE=single
TP_SIZE=1

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
# 67 GB BF16 weights + activations + KV → 0.85 leaves ~18 GiB headroom
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# --kv-cache-dtype fp8                : compress KV (model weights stay BF16)
# --reasoning-parser qwen3            : parse <think>...</think> as reasoning_content
# --enable-chunked-prefill            : reduce TTFT under concurrency
# --compilation-config use_inductor_graph_partition=true :
#     Qwen3.5/3.6 hybrid Mamba/Attention + torch.compile codegen workaround
# --limit-mm-per-prompt {"image":1,"audio":0,"video":0} :
#     wrapper arch has vision_config; allow 1 image, disable audio/video
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --reasoning-parser qwen3 --enable-chunked-prefill --compilation-config {"use_inductor_graph_partition":true} --limit-mm-per-prompt {"image":1,"audio":0,"video":0}

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---- Model-specific env vars (BF16, no static quantization) ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
