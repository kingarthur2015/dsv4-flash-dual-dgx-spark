# =============================================================================
# wangzhang/Qwen3.5-122B-A10B-abliterix-FP8 — TP=2 Dual DGX Spark
#
# Source: wangzhang/Qwen3.5-122B-A10B-abliterix (BF16, gated, ~244 GB)
# Quant:  llmcompressor FP8_DYNAMIC (compressed-tensors W8A8) → ~122 GB
#
# Architecture (Qwen3_5MoeForCausalLM, hybrid Mamba/Attention MoE):
#   - 48 layers: 36 linear_attention (GLA/Mamba2-style) + 12 full_attention
#   - 256 experts, top-8 active, ~10B active params
#   - hidden_size 3072, head_dim 256, GQA 32→2
#   - moe_intermediate_size 1024, shared_expert_intermediate_size 1024
#   - mtp_num_hidden_layers=1 (MTP speculative decoding available)
#   - mrope_interleaved (multimodal-ready, but no actual vision config)
#   - max_position 262144 (served at 32768)
#
# Sizing on dual GB10 (121 GiB unified each):
#   - FP8 weights ~122 GB total → ~61 GB / rank
#   - Plus KV (fp8) + activations + Ray buffers → comfortable inside 121 GiB
#
# APPLY_TEXT_ONLY_SHIM=1: model declares vision tokens in chat_template but
# has no vision_config — entrypoint applies patches/patch_qwen35_moe_text.py
# to register a dummy vision config so vLLM serves it as text-only.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-ngc2603

# ---- Model ----
# Quantized output of quantize/quantize_qwen35_abliterix_fp8_direct.py
MODEL_PATH=[model_path]/wangzhang/Qwen3.5-122B-A10B-abliterix-FP8
MODEL_CONTAINER_PATH=/models/wangzhang/Qwen3.5-122B-A10B-abliterix-FP8
SERVED_MODEL_NAME=wangzhang/Qwen3.5-122B-A10B-abliterix

# ---- Cluster (dual-rdma, TP=2 required) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.88
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# --quantization compressed-tensors : auto-detected from quantization_config
#                                     in config.json (FP8 W8A8 dynamic).
# --kv-cache-dtype fp8              : FP8 KV cache to save residency at 32K.
# --enable-chunked-prefill          : reduce TTFT under concurrency.
# --reasoning-parser qwen3          : parse <think>...</think> as reasoning_content.
# --compilation-config use_inductor_graph_partition=true :
#     Qwen3.5/3.6 hybrid + torch.compile codegen SyntaxError workaround.
# NOTE: config has mtp_num_hidden_layers=1 but safetensors index has zero
#       MTP-prefixed tensors (verified 2026-05-16). Speculative decoding
#       removed; can re-enable if quantization output preserves MTP weights.
VLLM_EXTRA_ARGS=--quantization compressed-tensors --kv-cache-dtype fp8 --enable-chunked-prefill --reasoning-parser qwen3 --compilation-config {"use_inductor_graph_partition":true}

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---- Patches ----
# Apply text-only shim (chat_template has vision tokens, model lacks vision_config).
APPLY_TEXT_ONLY_SHIM=1

# ---- Quant-backend toggles (FP8 path uses compressed-tensors, not NVFP4) ----
# vLLM 0.20 validates VLLM_NVFP4_GEMM_BACKEND as a strict enum even when
# the model has no NVFP4 modules — empty string is rejected. Set a valid
# placeholder; harmless since compressed-tensors W8A8 picks CutlassFP8 path.
VLLM_NVFP4_GEMM_BACKEND=cutlass
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_MARLIN_USE_ATOMIC_ADD=0
