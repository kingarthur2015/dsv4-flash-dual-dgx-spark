# =============================================================================
# Qwen3.6-27B PrismaSCOUT — Blackwell NVFP4-BF16 — TP=2 Multi-Node
#
# Pre-quantized PrismaSCOUT checkpoint (rdtand/...) packed in compressed-tensors
# NVFP4 + BF16 sidecars, served from /models/google/... on both Sparks.
# Speculative decoding: MTP n=3 (default for this preset). DFlash is a documented
# experimental swap-in, see README.md (Supported Models).
#
# This preset is consumed by docker-compose.yml, which
# also passes VLLM_NVFP4_GEMM_BACKEND=flashinfer-cutlass through to the
# container (the shared docker-compose.yml does not pipe that var through).
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-ngc2603

# ---- Model ----
MODEL_PATH=[model_path]/google/Qwen3.6-27B-PrismaSCOUT-Blackwell-NVFP4-BF16-vllm
MODEL_CONTAINER_PATH=/models/google/Qwen3.6-27B-PrismaSCOUT-Blackwell-NVFP4-BF16-vllm
SERVED_MODEL_NAME=rdtand/Qwen3.6-27B-PrismaSCOUT-Blackwell-NVFP4-BF16-vllm

# ---- Cluster (dual-rdma, TP=2 required) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# Defaults the spec asks for:
#   --quantization compressed-tensors   (explicit; some loaders prefer it pinned)
#   --kv-cache-dtype fp8                (keep KV residency low at 32k)
#   --enable-prefix-caching             (already set by entrypoint.sh — harmless)
#   --enable-chunked-prefill            (better TTFT scaling under load)
#   --reasoning-parser qwen3
#   --speculative-config MTP n=3        (1차 안정성 확인용 기본값)
# DFlash 옵션은 기본값에서 빠져 있습니다. README.md (Supported Models) 참고.
VLLM_EXTRA_ARGS=--quantization compressed-tensors --kv-cache-dtype fp8 --enable-chunked-prefill --reasoning-parser qwen3 --speculative-config {"method":"mtp","num_speculative_tokens":3}

# ---- Model-specific env vars ----
# NVFP4 GEMM backend: flashinfer-cutlass (PrismaSCOUT 권장).
# 이 변수는 shared docker-compose.yml 에는 없고, 본 preset 전용
# docker-compose.yml 에서 컨테이너로 전달됩니다.
VLLM_NVFP4_GEMM_BACKEND=flashinfer-cutlass
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
