# =============================================================================
# wangzhang/Qwen3.5-122B-A10B-abliterated-FP8 — TP2 Multi-Node, pre-quantized FP8
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-ngc2603

# ---- Model ----
MODEL_PATH=[model_path]/wangzhang_Qwen3.5-122B-A10B-abliterated-FP8
MODEL_CONTAINER_PATH=/models/wangzhang_Qwen3.5-122B-A10B-abliterated-FP8
SERVED_MODEL_NAME=wangzhang/Qwen3.5-122B-A10B-abliterated

# ---- Cluster ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=32768

# ---- Extra args ----
VLLM_EXTRA_ARGS=--enable-chunked-prefill --reasoning-parser qwen3

# ---- Model-specific env vars ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0

# ---- Patches ----
APPLY_TEXT_ONLY_SHIM=1
