# ---- Image ----
VLLM_IMAGE=vllm-spark:v020-fi064

# ---- Model ----
MODEL_PATH=/home/bjk110/Documents/Models/Qwen/wangzhang_Qwen3.5-122B-A10B-abliterated
MODEL_CONTAINER_PATH=/models/wangzhang_Qwen3.5-122B-A10B-abliterated
SERVED_MODEL_NAME=wangzhang/Qwen3.5-122B-A10B-abliterated

# ---- Cluster ----
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
