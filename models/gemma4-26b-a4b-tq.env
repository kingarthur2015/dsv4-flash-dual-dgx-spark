# =============================================================================
# Gemma 4 26B-A4B-it + TurboQuant KV Cache — TP1 Single-Node
# BF16 MoE (26B/4B active) + TurboQuant 4-bit KV cache
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-tq

# ---- Model ----
MODEL_PATH=[model_path]/google_gemma-4-26B-A4B-it
MODEL_CONTAINER_PATH=/models/google_gemma-4-26B-A4B-it
SERVED_MODEL_NAME=google/gemma-4-26B-A4B-it

# ---- Cluster ----
CLUSTER_MODE=single
TP_SIZE=1
#HEAD_ROCE_IP=10.10.10.1
#WORKER_ROCE_IP=10.10.10.2
#ROCE_IF_NAME=enp1s0f0np0
#IB_HCA_NAME=rocep1s0f0
#RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=32768

# ---- Extra args (TurboQuant KV cache) ----
VLLM_EXTRA_ARGS=--enable-chunked-prefill --kv-cache-dtype turboquant_k8v4

# ---- Model-specific env vars ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
