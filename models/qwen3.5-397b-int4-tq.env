# =============================================================================
# Qwen3.5-397B-A17B INT4 (AutoRound) + TurboQuant KV Cache — TP2 Multi-Node
# Weights: INT4 AutoRound (Marlin). KV cache: TurboQuant (most aggressive first).
# =============================================================================

# ---- Image (TurboQuant rebased branch) ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-tq

# ---- Model ----
MODEL_PATH=[model_path]/Qwen/Intel_Qwen3.5-397B-A17B-int4-AutoRound
MODEL_CONTAINER_PATH=/models/Qwen3.5-397B-A17B-int4-AutoRound
SERVED_MODEL_NAME=Qwen/Qwen3.5-397B-A17B-int4-AutoRound

# ---- Cluster ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# Testing cascade: turboquant_3bit_nc (4.9x) → turboquant_4bit_nc (3.8x) → turboquant_k8v4
#
# use_inductor_graph_partition=true: Qwen3.5 hybrid models include GDN
# (Gated Delta Network) layers whose torch.ops.vllm.gdn_attention_core takes
# a LayerName opaque arg. vLLM main 95995bbe's compilation/codegen.py
# `_node_ref()` does not honor LayerName.__fx_repr__() and emits the default
# repr (`<...LayerName object at 0x...>`) into the generated execution
# function source, which then dies in `exec(code)` with
# `SyntaxError: invalid syntax` during EngineCore init. Switching to
# Inductor graph partitioning bypasses the vLLM split-by-codegen path so
# torch.compile + CUDAGraph stay enabled. Drop this once upstream lands a
# fix (track via patches/check_sm120_upstream.sh-style monitor).
VLLM_EXTRA_ARGS=--kv-cache-dtype turboquant_3bit_nc --reasoning-parser qwen3 --enable-auto-tool-choice --tool-call-parser qwen3_coder --compilation-config {"use_inductor_graph_partition":true}

# ---- Model-specific env vars ----
VLLM_MARLIN_USE_ATOMIC_ADD=1
VLLM_USE_FLASHINFER_MOE_FP4=0
