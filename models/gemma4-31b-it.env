# =============================================================================
# google/gemma-4-31B-it — TP=1 Single-Node
#
# Architecture (Gemma4ForConditionalGeneration, dense multimodal):
#   - 60 layers
#   - hidden_size 5376, GQA 32→16, head_dim 168
#   - vocab 262144, max_position 262144 (served at 32768)
#   - vision + audio config (multimodal), text-first dispatch
#
# Sizing on single GB10 (121 GiB unified):
#   - BF16 weights ~62 GB → fits one node with KV-cache headroom
#
# Image: v022-d568 (NGC 26.04 base + vLLM v0.21.0 + PR#35568 cherry-pick
#                   + FlashInfer 0.6.11.post3 + Transformers 5.8.1
#                   + Triton 3.7.0 + NCCL 2.30.4).
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v022-d568

# ---- Model ----
MODEL_PATH=[model_path]/google/google_gemma-4-31B-it
MODEL_CONTAINER_PATH=/models/google_gemma-4-31B-it
SERVED_MODEL_NAME=google/gemma-4-31B-it

# ---- Cluster ----
CLUSTER_MODE=single
TP_SIZE=1

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
# 62 GB BF16 weights + activations + KV → 0.85 leaves ~18 GiB headroom on GB10
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# --enable-chunked-prefill : reduce TTFT under concurrency
# --limit-mm-per-prompt    : allow 1 image and 0 audio per prompt for first-boot
#                            verification (audio still beta in vLLM 0.21)
VLLM_EXTRA_ARGS=--enable-chunked-prefill --dtype bfloat16 --limit-mm-per-prompt {"image":1,"audio":0,"video":0}

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---- Disabled MoE/NVFP4 hooks (Gemma4 is dense BF16) ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
