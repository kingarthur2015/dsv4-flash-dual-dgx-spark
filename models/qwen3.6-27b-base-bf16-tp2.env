# =============================================================================
# Qwen/Qwen3.6-27B (base, BF16) — TP=2 Multi-Node
#
# Original BF16 source of the PrismaSCOUT quantized variant. The PrismaSCOUT
# (NVFP4) preset fails at TP=2 because the vision tower's intermediate_size
# (4304) splits to 2152 per rank, violating the FP4 16-multiple alignment
# requirement (`scaled_fp4_quant` last-dim assertion). The base BF16 model
# has no such alignment constraint and runs cleanly under TP=2.
#
# Trade-off vs PrismaSCOUT: ~54 GB weights vs ~20 GB. With TP=2, that's
# ~27 GB/Spark for weights — comfortable inside GB10's 121 GiB unified pool
# with fp8 KV at 32k.
#
# MTP heads are present in the base (text_config.mtp_num_hidden_layers=1),
# so speculative-config MTP n=3 still works.
#
# Used by docker-compose.yml (PRESET arg of the
# lifecycle scripts swaps env_file to this file).
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-ngc2603

# ---- Model ----
MODEL_PATH=[model_path]/Qwen/Qwen3.6-27B
MODEL_CONTAINER_PATH=/models/Qwen/Qwen3.6-27B
SERVED_MODEL_NAME=Qwen/Qwen3.6-27B

# ---- Cluster (dual-rdma, TP=2 required) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# No --quantization flag — model is raw BF16.
# KV fp8 keeps cache residency low at 32k.
# MTP n=3 speculative decoding (base model already has MTP heads).
#
# --compilation-config use_inductor_graph_partition=true:
#   Required workaround for the Qwen3.5/Qwen3.6 hybrid + torch.compile codegen
#   SyntaxError (LayerName repr emitted into exec'd source). See README.md
#   "Troubleshooting" → "SyntaxError: invalid syntax in compilation/codegen.py".
#   Keeps CUDA graph + torch.compile enabled; cold start is ~2× slower than
#   --enforce-eager but inference throughput is preserved.
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --enable-chunked-prefill --reasoning-parser qwen3 --speculative-config {"method":"mtp","num_speculative_tokens":3} --compilation-config {"use_inductor_graph_partition":true}

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---- Quant-backend toggles (all 0 since BF16) ----
VLLM_NVFP4_GEMM_BACKEND=
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
