# =============================================================================
# RedHatAI Qwen3.5-122B-A10B-NVFP4 + TurboQuant KV Cache — TP1 Single-Node
# NVFP4 weights + TurboQuant 4-bit KV cache (FP8 keys + 4-bit values)
# Expected: ~2.6x KV cache capacity vs bf16
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-tq

# ---- Model ----
MODEL_PATH=[model_path]/RedHatAI_Qwen3.5-122B-A10B-NVFP4
MODEL_CONTAINER_PATH=/models/RedHatAI_Qwen3.5-122B-A10B-NVFP4
SERVED_MODEL_NAME=RedHatAI/Qwen3.5-122B-A10B-NVFP4

# ---- Cluster ----
CLUSTER_MODE=single
TP_SIZE=1
#HEAD_ROCE_IP=10.10.10.1
#WORKER_ROCE_IP=10.10.10.2
#ROCE_IF_NAME=enp1s0f0np0
#IB_HCA_NAME=rocep1s0f0
#RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=32768

# ---- Extra args (TurboQuant KV cache) ----
# turboquant_k8v4: FP8 keys + 4-bit values (best quality/compression tradeoff)
# Alternatives: turboquant_4bit_nc (3.8x), turboquant_3bit_nc (4.9x)
VLLM_EXTRA_ARGS=--enable-chunked-prefill --kv-cache-dtype turboquant_k8v4 --reasoning-parser qwen3

# ---- Model-specific env vars ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
