# =============================================================================
# Qwen3.5-122B-A10B PrismaQuant 4.76bpp — TP1 Single-Node
#
# Mixed-precision via vLLM stock compressed-tensors:
#   NVFP4 (bulk MoE experts + medium-sensitivity dense Linears + visual tower)
# + MXFP8 (high-sensitivity dense Linears)
# + BF16  (router, norms, biases, embed/lm_head, pos_embed)
# Disk: 72GB / Peak VRAM ~86GB with fp8 KV @ 32k on GB10 (121GB unified).
# MTP speculative decoding: on this setup n=1 is the best balance.
#   - n=3: repetition loops observed in long roleplay generation
#   - n=1: best KQA throughput, no loops, clean output
#   - n=0: best llama-benchy throughput but higher sampling variance
# Override VLLM_EXTRA_ARGS below to pick a different n.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-ngc2603

# ---- Model ----
MODEL_PATH=[model_path]/rdtand_Qwen3.5-122B-A10B-PrismaQuant-4.75bit-vllm
MODEL_CONTAINER_PATH=/models/Qwen3.5-122B-A10B-PrismaQuant
SERVED_MODEL_NAME=Qwen/Qwen3.5-122B-A10B-PrismaQuant

# ---- Cluster ----
CLUSTER_MODE=single
TP_SIZE=1
#HEAD_ROCE_IP=10.10.10.1
#WORKER_ROCE_IP=10.10.10.2
#ROCE_IF_NAME=enp1s0f0np0
#IB_HCA_NAME=rocep1s0f0
#RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# MTP speculative decoding (n=1) — best balance from local benchmarks.
# fp8 KV cache keeps peak residency near 86GB on GB10.
# (--trust-remote-code is already added by entrypoint.sh by default.)
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --reasoning-parser qwen3 --speculative-config {"method":"mtp","num_speculative_tokens":1}

# ---- Model-specific env vars ----
# FlashInfer NVFP4 attention (explicit preference for compressed-tensors NVFP4).
VLLM_USE_FLASHINFER_NVFP4=1
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
