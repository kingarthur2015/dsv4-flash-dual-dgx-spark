# =============================================================================
# Qwen3.6-35B-A3B FP16 — TP1 Single-Node (Experimental Test Preset)
#
# Weights: original bf16/fp16 (NOT quantized). Served as the raw upstream model.
# KV cache: fp8 (optimization only — does NOT change the model weights).
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-ngc2603

# ---- Model ----
MODEL_PATH=[model_path]/Qwen_Qwen3.6-35B-A3B
MODEL_CONTAINER_PATH=/models/Qwen3.6-35B-A3B
SERVED_MODEL_NAME=Qwen/Qwen3.6-35B-A3B

# ---- Cluster ----
CLUSTER_MODE=single
TP_SIZE=1
#HEAD_ROCE_IP=10.10.10.1
#WORKER_ROCE_IP=10.10.10.2
#ROCE_IF_NAME=enp1s0f0np0
#IB_HCA_NAME=rocep1s0f0
#RAY_PORT=6379

# ---- vLLM Serving (conservative starting values) ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# kv-cache-dtype=fp8 compresses the KV cache only; model weights stay bf16/fp16.
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --reasoning-parser qwen3 --enable-chunked-prefill

# ---- Model-specific env vars ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
