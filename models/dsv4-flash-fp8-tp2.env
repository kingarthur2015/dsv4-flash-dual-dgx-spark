# =============================================================================
# DeepSeek-V4-Flash (official FP8) — TP=2 Dual DGX Spark (GB10, SM 12.1a)
#
# Operational best (current benchmark, see docs/dsv4-flash-tp2.md §6 Test #7):
#   - DISTRIBUTED_BACKEND=ray (default; preserves regression safety for
#       other dual-rdma presets)
#   - MAX_NUM_SEQS=4
#   - MAX_NUM_BATCHED_TOKENS=4192
#   - MTP off
#   → peak ≈69 t/s decode @ c=4, ≈800 t/s prefill @ pp2048 c=4.
#
# mp is supported (DISTRIBUTED_BACKEND=mp) for no-Ray / forum-baseline
# reproduction. mp + MTP-off remains a valid performance candidate but
# requires re-validation after the entrypoint mp command shape stabilizes.
#
# Quant: deepseek-ai/DeepSeek-V4-Flash (official FP8, ~149 GB safetensors)
# Image: ghcr.io/bjk110/vllm-spark:dsv4-d568
# See docs/dsv4-flash-tp2.md for full build / deploy / benchmark guide.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:dsv4-d568

# ---- Model (edit MODEL_PATH to the local snapshot path on both spark nodes) ----
MODEL_PATH=[model_path]
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-v4-flash

# ---- Cluster (replace placeholders with your dual-Spark RoCE values) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=<RAY_PORT>

# ---- Backend selection (DISTRIBUTED_BACKEND=ray|mp) ----
# ray (default): Ray-based head/worker — established path for all dual-rdma
#                 presets in this repo. Recommended for backward compatibility.
# mp           : vLLM SPMD via torch.distributed (no Ray). MASTER_ADDR
#                 defaults to HEAD_ROCE_IP if unset.
DISTRIBUTED_BACKEND=ray
MASTER_ADDR=<HEAD_ROCE_IP>
MASTER_PORT=<MASTER_PORT>

# ---- vLLM Serving (operational best — Test #7) ----
HOST_PORT=8000
MAX_MODEL_LEN=200000
# At MAX_MODEL_LEN=200000 and KV pool ≈1.92M tokens, MAX_NUM_SEQS=4 uses
# ≈4 × 200,000 / 1,919,636 ≈ 42% of the pool — comfortable headroom.
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.85
# 4192 keeps the KV pool at maximum. For prefill-heavy workloads, bump to
# 8192 and enable MTP n=2 (see docs §8 Test #9 — trades decode throughput
# for higher prefill peak).
MAX_NUM_BATCHED_TOKENS=4192

# ---- DeepSeek-V4 Flash specific vllm serve args ----
# --kv-cache-dtype fp8                : FP8_BLOCK attention KV cache
# --enable-expert-parallel            : EP across TP=2 ranks
# --block-size 256                    : larger paged-attention blocks (vs default 16)
# --tokenizer-mode deepseek_v4        : DSV4 tokenizer
# --tool-call-parser deepseek_v4      : DSV4 tool calls
# --enable-auto-tool-choice
# --reasoning-parser deepseek_v4      : DSV4 reasoning channel
# --reasoning-config ...              : forces think tags as reasoning
# --default-chat-template-kwargs ...  : enable <think> by default
# --compilation-config {"cudagraph_mode":"FULL_AND_PIECEWISE","custom_ops":["all"]}
# --load-format safetensors           : explicit safetensors loader
#
# MTP (--speculative-config) intentionally OFF: in the measured GB10 TP=2
# cross-node configuration it reduced overall throughput (see docs §7).
# To re-enable for testing, append:
#   --speculative-config {"method":"deepseek_mtp","num_speculative_tokens":2}
# and consider raising MAX_NUM_BATCHED_TOKENS to 8192.
#
# NOTE: --attention_config.use_fp4_indexer_cache=True is NOT enabled here.
# jasl/vllm guards it with a "requires Blackwell datacenter GPUs" check, so
# on GB10 (Blackwell consumer SM121) the boot path uses FP8 Lightning
# Indexer cache (visible in logs as "Using FP8 indexer cache").
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --enable-expert-parallel --block-size 256 --tokenizer-mode deepseek_v4 --tool-call-parser deepseek_v4 --enable-auto-tool-choice --reasoning-parser deepseek_v4 --reasoning-config {"reasoning_parser":"deepseek_v4","reasoning_start_str":"<think>","reasoning_end_str":"</think>"} --default-chat-template-kwargs {"thinking":true} --compilation-config {"cudagraph_mode":"FULL_AND_PIECEWISE","custom_ops":["all"]} --load-format safetensors

# ---- Runtime env (DSV4-specific) ----
# Per eugr/spark-vllm-docker PR #219 recipes/deepseek-v4-flash.yaml `env:` block:
TORCH_CUDA_ARCH_LIST=12.1a
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_TRITON_MLA_SPARSE=1
FLASHINFER_DISABLE_VERSION_CHECK=1
TILELANG_CLEANUP_TEMP_FILES=1
DG_JIT_USE_NVRTC=0
DG_JIT_NVCC_COMPILER=/usr/local/cuda/bin/nvcc
DG_JIT_PRINT_COMPILER_COMMAND=1
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN

# ---- Runtime env (general) ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---- Disabled (DSV4 uses native FP8, not Marlin/NVFP4) ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_MOE_FORCE_MARLIN=0
