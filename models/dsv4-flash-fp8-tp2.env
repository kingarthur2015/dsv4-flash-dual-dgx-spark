# =============================================================================
# DeepSeek-V4-Flash (official FP8) — TP=2 Dual DGX Spark (GB10, SM 12.1a)
#
# Quant: deepseek-ai/DeepSeek-V4-Flash (official FP8)
#   - E4M3 128x128 block FP8 weights (~149 GB safetensors on disk)
#   - MTP heads (num_speculative_tokens=2)
#   - 200K max context window
#
# Image: vllm-spark:dsv4-d568
#   - Based on ghcr.io/bjk110/vllm-spark:v022-d568 (NGC 26.04, PyTorch 2.12.0a0,
#     FlashInfer 0.6.11.post3, Triton 3.7.0, NCCL 2.30.4, Transformers 5.8.1)
#   - vLLM replaced with jasl/vllm @ dda4668b (PR #41834 lineage, GB10 validated)
#     "Restore rowwise paged-MQA logits kernel for SM12x long context"
#   - patches/apply_dsv4_packed_mapping.py (defensive)
#
# Recipe source: developer forum post #43 (2026-05-14) on
#   https://forums.developer.nvidia.com/t/.../370309 and
#   eugr/spark-vllm-docker PR #219 (recipes/deepseek-v4-flash.yaml)
#
# Reported numbers (forum, 2x DGX Spark GB10 200Gbps RoCE, 2026-05-14):
#   - Cold start ~6 min; warm single-stream decode ~44 t/s
#   - Concurrency=2 aggregate ~45 t/s; TTFT short prompts ~2 s warm
#   - At 200K ctx, max_num_seqs=2 (KV budget). Lower MAX_MODEL_LEN raises seqs.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:dsv4-d568

# ---- Model ----
MODEL_PATH=/home/bjk110/Documents/Models/deepseek-ai/DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-v4-flash

# ---- Cluster ----
# Forum recipe uses --distributed-executor-backend mp (no Ray) across two nodes
# with --nnodes 2. Our entrypoint.sh always uses Ray for TP>=2. First-attempt
# strategy: keep Ray (validated by pasta-paul on dual-Spark TP=2 graphs-ON).
# If Ray Compiled DAG (#36237) hangs at boot, switch to mp via entrypoint patch.
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379

# ---- vLLM Serving (forum recipe defaults, 200K ctx) ----
HOST_PORT=8000
MAX_MODEL_LEN=200000
MAX_NUM_SEQS=2
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=4192
# block_size 256 (vs default 16) per recipe — reduces page table overhead at 200K ctx

# ---- DeepSeek-V4 Flash specific vllm serve args ----
# --kv-cache-dtype fp8                : FP8_BLOCK attention KV cache
# --enable-expert-parallel            : EP across TP=2 ranks (recipe requirement)
# --block-size 256                    : larger paged-attention blocks
# --tokenizer-mode deepseek_v4        : DSV4 tokenizer
# --tool-call-parser deepseek_v4      : DSV4 tool calls
# --enable-auto-tool-choice
# --reasoning-parser deepseek_v4      : DSV4 reasoning channel
# --reasoning-config ...              : forces think tags as reasoning
# --default-chat-template-kwargs '{"thinking":true}' : enable <think> by default
# --compilation-config {"cudagraph_mode":"FULL_AND_PIECEWISE","custom_ops":["all"]}
# --load-format safetensors           : explicit safetensors loader
#
# NOTE: forum recipe specifies `--distributed-executor-backend mp` with --nnodes 2.
# Our entrypoint.sh forces `--distributed-executor-backend ray` for TP>=2 since
# pasta-paul's 2026-05-06 GB10 validation used Ray graphs-ON. If Ray Compiled
# DAG bug #36237 hangs at boot, modify entrypoint.sh to use mp (and add --nnodes).
#
# NOTE: MTP (--speculative-config '{"method":"deepseek_mtp","num_speculative_tokens":2}')
# is mentioned in forum post #43 as a perf optimization (~68% acceptance, ~44 t/s).
# Omitted from first boot for simplicity; add after baseline boots successfully.
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --enable-expert-parallel --block-size 256 --tokenizer-mode deepseek_v4 --tool-call-parser deepseek_v4 --enable-auto-tool-choice --reasoning-parser deepseek_v4 --reasoning-config {"reasoning_parser":"deepseek_v4","reasoning_start_str":"<think>","reasoning_end_str":"</think>"} --default-chat-template-kwargs {"thinking":true} --compilation-config {"cudagraph_mode":"FULL_AND_PIECEWISE","custom_ops":["all"]} --load-format safetensors

# ---- Runtime env (DSV4-specific) ----
# Per eugr/spark-vllm-docker PR #219 recipes/deepseek-v4-flash.yaml `env:` block:
TORCH_CUDA_ARCH_LIST=12.1a
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_TRITON_MLA_SPARSE=1
FLASHINFER_DISABLE_VERSION_CHECK=1
TILELANG_CLEANUP_TEMP_FILES=1
DG_JIT_USE_NVRTC=0
DG_JIT_NVCC_COMPILER=/usr/local/cuda/bin/nvcc
DG_JIT_PRINT_COMPILER_COMMAND=1
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN

# ---- Runtime env (general) ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---- Disabled (DSV4 uses native FP8, not Marlin/NVFP4) ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_MOE_FORCE_MARLIN=0
