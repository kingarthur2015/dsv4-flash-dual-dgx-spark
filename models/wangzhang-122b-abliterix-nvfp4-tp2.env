# =============================================================================
# wangzhang/Qwen3.5-122B-A10B-abliterix-NVFP4 — TP=2 Dual DGX Spark
#
# Source: wangzhang/Qwen3.5-122B-A10B-abliterix (BF16, gated, ~244 GB)
# Quant:  fp8-quantizer/convert_bf16_to_nvfp4.py
#         (compressed-tensors nvfp4-pack-quantized W4A4, group_size=16)
#         → 70.4 GB / 15 shards
#
# Architecture (Qwen3_5MoeForCausalLM, hybrid Mamba/Attention MoE):
#   - 48 layers: 36 linear_attention (GLA/Mamba2-style) + 12 full_attention
#   - 256 experts, top-8 active, ~10B active params
#   - hidden_size 3072, head_dim 256, GQA 32→2
#   - moe_intermediate_size 1024, shared_expert_intermediate_size 1024
#   - max_position 262144 (served at 32768)
#
# Sizing on dual GB10 (121 GiB unified each):
#   - NVFP4 weights ~70 GB total → ~35 GB / rank
#   - Plus KV (fp8) + activations + Ray buffers → very comfortable inside 121 GiB
#
# Image: v022-d568 (NGC 26.04 + vLLM 0.21.0 + PR #35568 SM121 gates cherry-pick
#                   + FlashInfer 0.6.11.post3 + NCCL 2.30.4 + Triton 3.7.0).
# The PR #35568 cherry-pick is REQUIRED for NVFP4 on SM121 (DGX Spark GB10) —
# stock vLLM 0.21.0 gates the Marlin/CUTLASS NVFP4 paths SM120-only.
#
# APPLY_TEXT_ONLY_SHIM=1: model declares vision tokens in chat_template but
# has no vision_config — entrypoint applies patches/patch_qwen35_moe_text.py
# to register a dummy vision config so vLLM serves it as text-only.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v022-d568

# ---- Model ----
# Quantized output of fp8-quantizer/convert_bf16_to_nvfp4.py on spark01.
MODEL_PATH=[model_path]/wangzhang/Qwen3.5-122B-A10B-abliterix-NVFP4
MODEL_CONTAINER_PATH=/models/wangzhang/Qwen3.5-122B-A10B-abliterix-NVFP4
SERVED_MODEL_NAME=wangzhang/Qwen3.5-122B-A10B-abliterix

# ---- Cluster (dual-rdma, TP=2 required) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=4
# 0.80 leaves ~24 GiB headroom for Ray actors / CUDA context / Python on GB10
# unified memory — NVFP4 weights only need ~35 GiB / rank, plenty of room.
GPU_MEMORY_UTILIZATION=0.80
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# --quantization compressed-tensors : auto-detected from quantization_config
#                                     (NVFP4 W4A4 nvfp4-pack-quantized).
# --kv-cache-dtype fp8              : FP8 KV cache to save residency at 32K.
# --enable-chunked-prefill          : reduce TTFT under concurrency.
# --reasoning-parser qwen3          : parse <think>...</think> as reasoning_content.
# --compilation-config use_inductor_graph_partition=true :
#     Qwen3.5/3.6 hybrid + torch.compile codegen SyntaxError workaround.
# (--moe-backend flashinfer_cutlass NOT passed here — the VLLM_USE_FLASHINFER_MOE_FP4=1
#  env below selects the NVFP4 FlashInfer-CUTLASS MoE path inside vLLM.)
VLLM_EXTRA_ARGS=--quantization compressed-tensors --kv-cache-dtype fp8 --enable-chunked-prefill --reasoning-parser qwen3 --compilation-config {"use_inductor_graph_partition":true}

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---- Patches ----
# Apply text-only shim (chat_template has vision tokens, model lacks vision_config).
APPLY_TEXT_ONLY_SHIM=1

# ---- Quant-backend toggles (NVFP4 path) ----
# - VLLM_NVFP4_GEMM_BACKEND=flashinfer-cutlass : FlashInfer-CUTLASS NVFP4 GEMM on Blackwell.
#   Valid options (vLLM 0.21): flashinfer-cudnn | flashinfer-trtllm | flashinfer-cutlass
#                              | cutlass | marlin | emulation.
# - VLLM_USE_FLASHINFER_MOE_FP4=1 : enable FlashInfer-CUTLASS NVFP4 grouped-GEMM for
#                                   the MoE expert path (REQUIRED for NVFP4 MoE perf).
# - VLLM_MARLIN_USE_ATOMIC_ADD=0  : Marlin atomic add off (unused on NVFP4 path).
VLLM_NVFP4_GEMM_BACKEND=flashinfer-cutlass
VLLM_USE_FLASHINFER_MOE_FP4=1
VLLM_MARLIN_USE_ATOMIC_ADD=0
