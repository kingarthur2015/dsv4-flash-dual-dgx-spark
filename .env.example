# =============================================================================
# vLLM Spark — Unified Serving Configuration
# Copy a model preset or this file to .env:
#   cp models/qwen3.5-397b-int4.env .env
# =============================================================================

# ---- Image ----
# Pre-built vLLM image name (build with Dockerfile or Dockerfile.nvfp4)
VLLM_IMAGE=vllm-spark:v020-ngc2603

# ---- Model ----
# Host path to model weights
MODEL_PATH=/path/to/model/weights
# Container-internal mount point (must match VLLM_IMAGE expectations)
MODEL_CONTAINER_PATH=/models/ModelName
# Model name exposed via OpenAI-compatible API
SERVED_MODEL_NAME=Org/ModelName

# ---- Cluster ----
# Tensor-parallel size: 1 = standalone (no Ray), 2+ = multi-node via Ray
TP_SIZE=2
# RoCE/IB network IPs for head and worker
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
# Network interface and HCA names
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
# Ray head port
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=16384

# ---- Model-specific vllm serve extra args ----
# Space-separated additional flags passed to `vllm serve`
# Examples:
#   --kv-cache-dtype fp8 --reasoning-parser qwen3
#   --enable-chunked-prefill --enable-auto-tool-choice --tool-call-parser qwen3_coder
VLLM_EXTRA_ARGS=

# ---- Model-specific environment variables ----
# Leave empty to disable. Non-empty value activates the variable.
# INT4 AutoRound (Marlin kernel)
VLLM_MARLIN_USE_ATOMIC_ADD=0
# NVFP4 quantization
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_MOE_FORCE_MARLIN=0
