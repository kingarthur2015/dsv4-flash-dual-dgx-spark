# =============================================================================
# vLLM Spark — Unified Serving Configuration
#
# Two supported topologies:
#   (1) Single DGX Spark (default): one GB10, no RDMA, no Ray.
#   (2) Dual DGX Spark + 200 Gbps RoCE/IB: two nodes, TP=2.
#       For dual-rdma, the entrypoint supports two distributed backends:
#         - DISTRIBUTED_BACKEND=ray (default): established Ray actor mode.
#         - DISTRIBUTED_BACKEND=mp: SPMD via vLLM
#             --distributed-executor-backend mp --nnodes/--node-rank/
#             --master-addr/--master-port (worker adds --headless).
#             Use mp for no-Ray / forum-baseline / comparison testing.
#       Ray requires RAY_PORT. mp requires MASTER_ADDR/MASTER_PORT/NNODES/
#       NODE_RANK (defaults filled by entrypoint from HEAD_ROCE_IP/29501/
#       TP_SIZE/role).
#
# Pick a model preset and copy it to .env:
#   cp models/redhatai-122b-nvfp4.env .env       # single Spark, TP=1
#   cp models/qwen3.5-122b-fp8.env  .env         # dual Spark, TP=2 (Ray)
#   cp models/dsv4-flash-fp8-tp2.env .env        # DeepSeek-V4-Flash, TP=2
# =============================================================================

# ---- Image ----
# Pre-built vLLM image name. Active top-level builds: Dockerfile.v022-d568
# (general base) and Dockerfile.dsv4-d568 (DeepSeek-V4-Flash derivative).
# Legacy/intermediate builds live under dockerfiles/. Or pull from GHCR.
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v021-ngc2603

# ---- Model ----
# Host path to model weights
MODEL_PATH=/path/to/model/weights
# Container-internal mount point (must match VLLM_IMAGE expectations)
MODEL_CONTAINER_PATH=/models/ModelName
# Model name exposed via OpenAI-compatible API
SERVED_MODEL_NAME=Org/ModelName

# ---- Cluster topology ----
# CLUSTER_MODE: 'single' (one Spark, no RDMA) or 'dual-rdma' (two Sparks).
# Default 'single' so a fresh checkout works without RDMA setup.
CLUSTER_MODE=single
# Tensor-parallel size. Must be 1 in 'single' mode; 2+ requires 'dual-rdma'.
TP_SIZE=1

# ---- Dual-RDMA cluster networking (only for CLUSTER_MODE=dual-rdma) ----
# In 'single' mode these are ignored — entrypoint.sh forces VLLM_HOST_IP=127.0.0.1
# and clears NCCL/GLOO/UCX interface bindings, which is what avoids the
# "tcp://10.10.10.1:<port> server socket has timed out" c10d hang on a
# single Spark.
#
# Uncomment and edit for the dual-Spark RoCE configuration:
#HEAD_ROCE_IP=10.10.10.1
#WORKER_ROCE_IP=10.10.10.2
#ROCE_IF_NAME=enp1s0f0np0
#IB_HCA_NAME=rocep1s0f0
#RAY_PORT=6379

# NCCL_NVLS_ENABLE: NCCL NVLink-Switch (NVLS) collective path.
# Default upstream is 1. Set to 0 on NVLink-less hardware (e.g. DGX Spark
# pair with RoCE only) — NVLS is meaningless and can trigger regressions
# such as the NCCL 2.30.4 + ≥384-expert wedge reported in vLLM #40969
# (NVIDIA/nccl#2167).
#NCCL_NVLS_ENABLE=0

# ---- Multi-node backend selection (dual-rdma only) ----
# DISTRIBUTED_BACKEND: 'ray' (default, established) or 'mp' (SPMD via vLLM
#   --nnodes/--node-rank/--master-{addr,port}, follows eugr no-ray pattern).
# See README "Backend selection" section.
#DISTRIBUTED_BACKEND=ray
#MASTER_PORT=29501

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=16384

# ---- Model-specific vllm serve extra args ----
# Space-separated additional flags passed to `vllm serve`.
# Examples:
#   --kv-cache-dtype fp8 --reasoning-parser qwen3
#   --enable-chunked-prefill --enable-auto-tool-choice --tool-call-parser qwen3_coder
VLLM_EXTRA_ARGS=

# ---- Model-specific environment variables ----
# 0 = disabled (default).
# INT4 AutoRound (Marlin kernel)
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0

# ---- GB10 UMA escape hatch (DGX Spark only) ----
# VLLM_SKIP_INIT_MEMORY_CHECK=1 bypasses vLLM's request_memory() / profile
# pre-checks that assume discrete-GPU semantics and otherwise misread UMA
# free memory on GB10. Set to 1 only on Spark; harmless elsewhere because
# request_memory() check still surfaces real OOM at weight-load time. See
# docs/dsv4-flash-tp2.md §11.6 and patches/patch_skip_init_memory_check.py.
#VLLM_SKIP_INIT_MEMORY_CHECK=1
