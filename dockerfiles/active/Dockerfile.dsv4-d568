# syntax=docker/dockerfile:1.6
# =========================================================================
# vLLM on NVIDIA DGX Spark (GB10, SM121) — DeepSeek-V4-Flash on v022-d568 base
#
# Originally based on the developer-forum-pinned jasl/vllm `dda4668b` recipe
# (2026-05-13, "Restore rowwise paged-MQA logits kernel for SM12x long
# context"), then intentionally advanced to `edc82b614f51` (branch HEAD,
# 2026-05-19, +249 commits) to include later DSV4 MTP / SWA / SM12x fixes:
#   - 662b07732d3e  Fix DeepSeek V4 MTP small-batch graph hangs
#   - beb72fe2f050  Fix DeepSeek V4 MTP sparse SWA reordering
#   - 296b5bff3aff  Fix SWA cache block mask breaking prefix caching with Eagle/MTP
#   - 0e9bc3702e32  Remove ineffective DeepSeek V4 mHC warmup
# Plus broad SM12x kernel tuning (FP8 MQA logits, sparse MLA accumulate
# autotune, fp8_einsum/indexer num_warps tune, C128A KV gather overlap).
# jasl validated these on RTX PRO 6000 (SM120 datacenter); we revalidate
# end-to-end on GB10 (SM121 consumer).
#
# Stack:
#   FROM ghcr.io/bjk110/vllm-spark:v022-d568
#     (NGC 26.04 / PyTorch 2.12.0a0 / FlashInfer 0.6.12 / Triton 3.7.0
#      / NCCL 2.30.4 / Transformers 5.8.1)
#   + jasl/vllm @ edc82b614f51 (replaces v022-d568's vLLM 0.21.0+PR#35568)
#   + patches/apply_dsv4_packed_mapping.py (defensive — skips if branch
#     already defines packed_modules_mapping)
#   + patches/patch_split_module_compat.py (re-applied after vLLM swap)
#   + patches/moe_config_e256.json / e512.json (re-staged GB10 fused-MoE
#     configs)
#   + instanttensor (per eugr/spark-vllm-docker PR #219 recipe)
#
# Build: build on a node with ≥48 GiB RAM (vLLM C++/CUDA compile is memory-
# heavy). See docs/dsv4-flash-tp2.md §1.
#
# Verify:
#   docker run --rm --gpus all vllm-spark:dsv4-d568 \
#     /opt/scripts/verify_runtime.sh
#
# References:
#   - NVIDIA developer forum post #43:
#       https://forums.developer.nvidia.com/t/.../370309
#   - eugr/spark-vllm-docker PR #219 (DSV4 recipe)
# =========================================================================

ARG NGC_TAG=26.04-py3
ARG BUILD_JOBS=16

# jasl/vllm fork pinned by full SHA. See header for rationale on choosing
# edc82b614f51 over the forum-pinned dda4668b.
ARG VLLM_REPO_URL=https://github.com/jasl/vllm.git
ARG VLLM_BRANCH=codex/ds4-sm120-min-enable
ARG VLLM_COMMIT=ecb7466bade2ea3f2889e8dbb0f61ffc31e2e4ce

ARG TORCH_CUDA_ARCH="12.1a"

# =========================================================================
# STAGE 1: vLLM Builder (jasl fork @ edc82b614f51)
#
# Rebuilds vLLM against NGC 26.04 (PyTorch 2.12.0a0) so the wheel ABI
# matches the v022-d568 runner. jasl's branch was developed against
# NGC 26.03 / PyTorch 2.11; the PyTorch-2.12 compat patches from v022-d568
# (split_module_compat, hoist-kwarg strip) are applied defensively.
# =========================================================================
FROM nvcr.io/nvidia/pytorch:${NGC_TAG} AS vllm-builder

ARG BUILD_JOBS
ARG VLLM_REPO_URL
ARG VLLM_BRANCH
ARG VLLM_COMMIT
ARG TORCH_CUDA_ARCH
ENV MAX_JOBS=${BUILD_JOBS} \
    DEBIAN_FRONTEND=noninteractive \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH} \
    PATH=/usr/lib/ccache:$PATH \
    CCACHE_DIR=/root/.ccache \
    CCACHE_MAXSIZE=50G \
    CCACHE_COMPRESS=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends git ninja-build ccache && \
    rm -rf /var/lib/apt/lists/*

# Clone jasl/vllm and pin to exact commit. Fetch SHA directly (not branch)
# so the build is robust to upstream branch rebases — historical commits
# remain reachable via direct SHA fetch even after force-push.
RUN git clone ${VLLM_REPO_URL} /workspace/vllm-src && \
    cd /workspace/vllm-src && \
    git fetch origin ${VLLM_COMMIT} && \
    git checkout ${VLLM_COMMIT} && \
    ACTUAL=$(git rev-parse HEAD) && \
    echo "vLLM pinned to: ${ACTUAL} (jasl fork, branch-of-record: ${VLLM_BRANCH})" && \
    echo "${ACTUAL}" | grep -q "^${VLLM_COMMIT}" || \
      (echo "FATAL: commit mismatch — expected ${VLLM_COMMIT}*, got ${ACTUAL}" && exit 1) && \
    git config user.email "build@vllm-spark.local" && \
    git config user.name "vllm-spark builder"

# Cherry-pick A-group scheduler/decode-protection commits on top of the relax
# base (edc82b614f51). These 4 commits touch only scheduler.py + sm12x_mqa.py
# (pure Python, no C++/CUDA) and verified to apply cleanly (2026-05-27). They
# add long-prefill-vs-active-decode scheduling protection valuable for 200k-ctx
# serving, while deliberately EXCLUDING the sparse-MLA-split / SM120-cleanup
# commits suspected of the 5d64798 bump load-time thrash. If this image boots
# clean at operational config, the thrash culprit is narrowed to those excluded
# commits. See memory jasl_bump_2026_05_25_eval (2026-05-27 cherry-pick eval).
ARG VLLM_CHERRY_PICKS=""
RUN cd /workspace/vllm-src && \
    git fetch origin ${VLLM_BRANCH} && \
    for c in ${VLLM_CHERRY_PICKS}; do \
      git cherry-pick -x $c || (echo "FATAL: cherry-pick failed on $c" && git cherry-pick --abort && exit 1); \
    done && \
    echo "[cherry-pick] applied A-group (scheduler decode-protection): ${VLLM_CHERRY_PICKS}"

# Apply packed_modules_mapping patch — defensive (skips if already present in jasl branch).
COPY patches/apply_dsv4_packed_mapping.py /tmp/apply_dsv4_packed_mapping.py
RUN python3 /tmp/apply_dsv4_packed_mapping.py \
      /workspace/vllm-src/vllm/model_executor/models/deepseek_v4.py || \
    echo "[patch] packed_mapping skipped (anchor not found — likely already in jasl branch)"

# PyTorch 2.11/2.12-alpha compat: strip hoist=True kwarg from register_opaque_type().
COPY patches/fix_pytorch211_compat.py /tmp/fix_pytorch211_compat.py
RUN cd /workspace/vllm-src && python3 /tmp/fix_pytorch211_compat.py || \
    echo "[patch] fix_pytorch211_compat not applicable on jasl branch"

RUN pip install -q setuptools setuptools-scm setuptools-rust ninja cmake wheel packaging

# Build vLLM wheel
RUN --mount=type=cache,id=ccache-dsv4-d568,target=/root/.ccache \
    cd /workspace/vllm-src && \
    SETUPTOOLS_SCM_PRETEND_VERSION="0.20.0.dev" \
    VLLM_TARGET_DEVICE=cuda \
    python3 setup.py bdist_wheel -d /workspace/wheels && \
    ls -lh /workspace/wheels/*.whl && \
    echo "[vllm] Wheel built (jasl/vllm @ ${VLLM_COMMIT})"


# =========================================================================
# STAGE 2: Runner (inherit v022-d568 — FlashInfer / Triton / NCCL / Transformers
# all preinstalled). Only swap vLLM and add DSV4-specific bits.
# =========================================================================
FROM ghcr.io/bjk110/vllm-spark:v022-d568-tx590 AS runner

LABEL org.opencontainers.image.source="https://github.com/bjk110/spark_vllm_docker"
LABEL org.opencontainers.image.description="vLLM jasl@ecb7466bade2 HEAD 2026-06-01 (+25 commits over edc82b, A-group absorbed) on v022-d568-tx590 (NGC 26.04 / FlashInfer 0.6.12 / Transformers 5.9.0) — requires VLLM_USE_BREAKABLE_CUDAGRAPH=0 to avoid garble on GB10"
LABEL org.opencontainers.image.licenses="Apache-2.0"

ARG TORCH_CUDA_ARCH=12.1a
ENV TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH}

# Uninstall the v022-d568 vLLM (0.21.0+PR#35568) before installing the jasl wheel.
RUN pip uninstall -y vllm 2>/dev/null || true

# Install jasl/vllm wheel (edc82b614f51).
RUN --mount=type=bind,from=vllm-builder,source=/workspace/wheels,target=/mount/vllm \
    pip install /mount/vllm/*.whl --no-deps && \
    python3 -c "import vllm; print(f'[vllm] {vllm.__version__} installed')" && \
    python3 -c "from pathlib import Path; \
      so = Path('/usr/local/lib/python3.12/dist-packages/vllm/_C_stable_libtorch.abi3.so'); \
      assert so.exists(), f'{so} not found'; \
      print(f'_C_stable_libtorch.abi3.so: {so.stat().st_size/1e6:.1f} MB')"

# Re-resolve runtime deps (jasl branch may declare new requirements).
RUN --mount=type=cache,id=uv-dsv4-d568,target=/root/.cache/uv \
    DEPS=$(pip show vllm 2>/dev/null | grep ^Requires | sed 's/Requires: //' | tr ',' '\n' | \
      sed 's/^ *//;s/ *$//' | grep -v -E '^(torch|torchvision|torchaudio|flashinfer|$)' | \
      tr '\n' ' ') && \
    uv pip install --system $DEPS || \
    echo "[deps] partial resolve — runtime imports will surface anything critical"

# instanttensor — listed in eugr/spark-vllm-docker PR #219 recipe.
# Available on PyPI. Tolerated to fail: fastsafetensors (already installed
# on the base image) is sufficient as a loader fallback.
RUN --mount=type=cache,id=uv-dsv4-d568,target=/root/.cache/uv \
    (uv pip install --system instanttensor && \
     echo "[deps] instanttensor installed") || \
    echo "[deps] instanttensor unavailable — recipe still works via fastsafetensors"

# PyTorch 2.12.0a0 compat: vLLM's `is_torch_equal_or_newer("2.12.0.dev")` returns True
# on NGC 26.04 PyTorch alpha, but that alpha predates the upstream `split_module(tuple_return=...)`
# commit. This patch swaps the static version check for a runtime signature probe.
# The v022-d568 base had this applied to its bundled vLLM, but we just replaced vLLM
# with the jasl wheel — re-apply to the new install.
COPY patches/patch_split_module_compat.py /tmp/patch_split_module_compat.py
RUN python3 /tmp/patch_split_module_compat.py

# GB10 UMA: add VLLM_SKIP_INIT_MEMORY_CHECK=1 env-var escape hatch for
# request_memory() pre-allocation check. See docs/dsv4-flash-tp2.md §11.6 —
# nvidia driver accumulates host-RAM reservations after a few minutes uptime,
# causing the check to reject well-sized configs that would actually fit.
# Patch is idempotent; with the env-var unset, behavior is unchanged.
COPY patches/patch_skip_init_memory_check.py /tmp/patch_skip_init_memory_check.py
RUN python3 /tmp/patch_skip_init_memory_check.py

# GB10 UMA cleanup: register VLLM_SKIP_INIT_MEMORY_CHECK in vllm/envs.py's
# environment_variables dict so the "Unknown vLLM environment variable
# detected" warning goes away on startup. See docs/dsv4-flash-tp2.md §11.7.
COPY patches/patch_envs_register_skip_memcheck.py /tmp/patch_envs_register_skip_memcheck.py
RUN python3 /tmp/patch_envs_register_skip_memcheck.py

# GB10 UMA: extend VLLM_SKIP_INIT_MEMORY_CHECK=1 to also relax the
# post-profile assertion in determine_available_memory(). The Linux
# kernel can reclaim page cache during profiling, raising the UMA free
# metric above the init snapshot and tripping vLLM's "other process
# released GPU memory" check. See docs/dsv4-flash-tp2.md §11.9.
COPY patches/patch_relax_profile_assertion.py /tmp/patch_relax_profile_assertion.py
RUN python3 /tmp/patch_relax_profile_assertion.py

# NOTE: patch_fadvise_safetensors.py (PR #35929 port) was tried and
# reverted (see docs §11.8). It legitimately changed the UMA free metric
# during profiling, which tripped the assertion we now relax above — but
# it also broke the safetensors zero-copy mmap flow (~5x slower load).
# A correct port requires the companion mem_utils.py changes from
# PR #35929 plus moving the fadvise call out of the per-shard loop. Until
# then we attack the assertion symptom, not the cache-pressure root cause.

# Restore the GB10-tuned fused-MoE configs that were placed by the base image's
# vLLM install (the path now points at the freshly installed jasl wheel).
COPY patches/moe_config_e256.json \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/configs/E=256,N=512,device_name=NVIDIA_GB10,dtype=fp8_w8a8,block_shape=[128,128].json
COPY patches/moe_config_e512.json \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/configs/E=512,N=512,device_name=NVIDIA_GB10,dtype=fp8_w8a8,block_shape=[128,128].json

# Confirm DSV4 architecture registration after install (transformers + vllm).
RUN python3 -c "from transformers.models.auto.configuration_auto import CONFIG_MAPPING_NAMES; \
                assert 'deepseek_v4' in CONFIG_MAPPING_NAMES, \
                  'deepseek_v4 not in transformers — bump TRANSFORMERS_VER on the base image'; \
                print('[transformers] deepseek_v4 config available')" && \
    python3 -c "from vllm.model_executor.models import ModelRegistry; \
                supported = ModelRegistry.get_supported_archs(); \
                assert 'DeepseekV4ForCausalLM' in supported, \
                  f'DeepseekV4ForCausalLM not in vLLM ModelRegistry: {sorted(supported)[:20]}...'; \
                print('[vllm] DeepseekV4ForCausalLM registered')"

# Re-run verification script.
RUN /opt/scripts/verify_imports.py 2>/dev/null && \
    echo "[verify] dsv4-d568 build-time checks passed" || \
    echo "[verify] WARN: verify_imports.py reported issues (may be DSV4-specific imports unavailable until GPU)"

EXPOSE 8000
