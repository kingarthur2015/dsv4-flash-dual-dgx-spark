# ---- Image ----
VLLM_IMAGE=aidendle94/sparkrun-vllm-ds4-gb10:production-ready

# ---- Model ----
MODEL_PATH=/home/bjk110/Documents/Models/deepseek-ai/DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-v4-flash

# ---- Cluster ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379
DISTRIBUTED_BACKEND=ray

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=262144
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.80
MAX_NUM_BATCHED_TOKENS=8192
MTP_NUM_TOKENS=1

# ---- Runtime env ----
TORCH_CUDA_ARCH_LIST=12.1a
FLASHINFER_CUDA_ARCH_LIST=12.1a
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_TRITON_MLA_SPARSE=1
FLASHINFER_DISABLE_VERSION_CHECK=1
TILELANG_CLEANUP_TEMP_FILES=1
DG_JIT_USE_NVRTC=0
DG_JIT_NVCC_COMPILER=/usr/local/cuda/bin/nvcc
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---- NCCL / RoCE tuning (from confirmed working config) ----
NCCL_NET=IB
NCCL_CUMEM_ENABLE=0
NCCL_CROSS_NIC=1
NCCL_IGNORE_CPU_AFFINITY=1

# ---- NCCL SO + JIT cache (use conda-bundled NCCL, persistent JIT cache) ----
VLLM_NCCL_SO_PATH=/opt/env/lib/python3.12/site-packages/nvidia/nccl/lib/libnccl.so.2
# VLLM_CACHE_ROOT set in entrypoint.unholy.sh → /cache/jit/vllm-cache

# ---- B12X kernel switches (unholy-fusion specific) ----
VLLM_USE_B12X_MOE=1
VLLM_USE_B12X_MHC=0
VLLM_USE_B12X_FP8_GEMM=0
VLLM_USE_B12X_SPARSE_INDEXER=0
VLLM_USE_B12X_WO_PROJECTION=0

# ---- Disabled / inapplicable ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_SKIP_INIT_MEMORY_CHECK=1
VLLM_USE_BREAKABLE_CUDAGRAPH=0
